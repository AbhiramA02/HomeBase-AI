generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  extensions = [vector]
}

// Placeholder model so migrations work;
model HealthCheck {
  id        String   @id @default(cuid())
  ok        Boolean  @default(true)
  checkedAt DateTime @default(now())
}